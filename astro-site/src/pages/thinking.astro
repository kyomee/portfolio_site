---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/layout/Navigation.astro';
import Footer from '../components/layout/Footer.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = allPosts[0];
const remainingPosts = allPosts.slice(1);
const categories = [...new Set(allPosts.map(p => p.data.category))];
---

<BaseLayout
  title="Thinking | Nakyum Song"
  description="Essays on brand strategy, marketing, and AI for marketers."
>
  <Navigation />

  <main class="thinking-page">
    <section class="thinking-hero">
      <div class="container">
        <span class="section-label">Thinking</span>
        <h1 class="page-title">Essays & Ideas</h1>
        <p class="page-subtitle">
          Notes on brand strategy, marketing systems, and how AI is reshaping the way marketers work.
        </p>
      </div>
    </section>

    <section class="thinking-content">
      <div class="container">
        {allPosts.length === 0 ? (
          <p class="empty-state">Essays coming soon.</p>
        ) : (
          <>
            <!-- Category filter bar -->
            <div class="filter-bar" id="filter-bar">
              <button class="filter-btn active" data-filter="all">All</button>
              {categories.map(cat => (
                <button class="filter-btn" data-filter={cat}>{cat}</button>
              ))}
            </div>

            <!-- Featured article (most recent) -->
            {featuredPost && (
              <a
                href={`/thinking/${featuredPost.slug}/`}
                class="article-card article-card--featured"
                data-category={featuredPost.data.category}
              >
                <span class="article-category">{featuredPost.data.category}</span>
                <h2 class="article-title">{featuredPost.data.title}</h2>
                <p class="article-excerpt">{featuredPost.data.description}</p>
                <div class="article-footer">
                  <span class="article-date">
                    {featuredPost.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </span>
                  <span class="read-more">Read more &raquo;</span>
                </div>
              </a>
            )}

            <!-- Remaining articles — 2-column grid -->
            <div class="articles-grid">
              {remainingPosts.map(post => (
                <a
                  href={`/thinking/${post.slug}/`}
                  class="article-card"
                  data-category={post.data.category}
                >
                  <span class="article-category">{post.data.category}</span>
                  <h2 class="article-title">{post.data.title}</h2>
                  <p class="article-excerpt">{post.data.description}</p>
                  <div class="article-footer">
                    <span class="article-date">
                      {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </span>
                    <span class="read-more">Read more &raquo;</span>
                  </div>
                </a>
              ))}
            </div>
          </>
        )}

        <div class="subscribe-cta">
          <h2>Get these in your inbox</h2>
          <p>I send notes when I figure something out worth keeping. No spam, unsubscribe anytime.</p>
          <a
            href="https://nakyumsong.substack.com/subscribe"
            target="_blank"
            rel="noopener"
            class="btn btn-primary"
          >
            Subscribe on Substack
            <span class="btn-arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .thinking-page {
    padding-top: var(--nav-height);
  }

  .thinking-hero {
    padding: var(--space-16) 0 var(--space-8);
    background-color: var(--color-bg-secondary);
  }

  .section-label {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-4);
  }

  .page-title {
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-4);
  }

  .page-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 550px;
  }

  .thinking-content {
    padding: var(--space-16) 0;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
  }

  .filter-btn {
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-btn.active,
  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(242, 97, 74, 0.06);
  }

  /* Card base */
  .article-card {
    display: block;
    text-decoration: none;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-accent);
  }

  /* Featured card */
  .article-card--featured {
    margin-bottom: var(--space-8);
  }

  .article-card--featured .article-title {
    font-size: 2rem;
  }

  /* 2-column grid */
  .articles-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  /* Filter hidden */
  .article-hidden {
    display: none !important;
  }

  .article-category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-3);
  }

  .article-title {
    font-size: var(--text-2xl);
    font-weight: var(--font-semibold);
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3);
    line-height: var(--leading-snug);
    transition: color var(--transition-base);
  }

  .article-card:hover .article-title {
    color: var(--color-accent);
  }


  .article-excerpt {
    font-size: var(--text-base);
    font-style: italic;
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-5);
  }

  .article-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .article-date {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .read-more {
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-accent);
  }

  .empty-state {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    text-align: center;
    padding: var(--space-12) 0;
  }

  .subscribe-cta {
    max-width: 500px;
    text-align: center;
    padding: var(--space-12);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    margin: 0 auto;
  }

  .subscribe-cta h2 {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-4);
  }

  .subscribe-cta p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    cursor: pointer;
    text-decoration: none;
    border: none;
  }

  .btn-primary {
    background: var(--gradient-accent);
    color: #ffffff;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  .btn-arrow {
    transition: transform var(--transition-base);
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .thinking-hero {
      padding: var(--space-12) 0 var(--space-6);
    }

    .page-title {
      font-size: var(--text-3xl);
    }

    .article-card--featured .article-title {
      font-size: var(--text-2xl);
    }

    .article-title {
      font-size: var(--text-xl);
    }

    .articles-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .page-title {
      font-size: var(--text-2xl);
    }

    .page-subtitle {
      font-size: var(--text-base);
    }

    .article-excerpt {
      font-size: var(--text-sm);
    }

    .subscribe-cta {
      padding: var(--space-8);
    }

    .subscribe-cta h2 {
      font-size: var(--text-xl);
    }
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const articleCards = document.querySelectorAll<HTMLElement>('.article-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      articleCards.forEach(card => {
        const match = filter === 'all' || card.dataset.category === filter;
        card.classList.toggle('article-hidden', !match);
      });
    });
  });
</script>
