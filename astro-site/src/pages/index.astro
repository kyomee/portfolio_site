---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/layout/Navigation.astro';
import Footer from '../components/layout/Footer.astro';
import ScrollReveal from '../components/interactive/ScrollReveal.astro';
import Subscribe from '../components/sections/Subscribe.astro';
import { Image } from 'astro:assets';
import profilePhoto from '../assets/images/nakyum-profile.jpeg';
---

<BaseLayout>
  <Navigation />
  <ScrollReveal />

  <main>
    <!-- Hero Section -->
    <section id="hero" class="hero section">

      <div class="container hero-content">
        <div class="hero-right" data-reveal="1">
          <div class="hero-photo">
            <Image
              src={profilePhoto}
              alt="Nakyum Song"
              width={600}
              height={800}
              format="webp"
              quality={85}
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>

        <div class="hero-left">
          <div class="hero-narrative">
            <p class="hero-greeting">Hi, I'm</p>
            <h1 class="hero-name">Nakyum Song</h1>
            <p class="hero-title">Global marketer and brand architect</p>
            <p class="hero-tagline">
              Based in Singapore &amp; Korea.
            </p>
          </div>

          <div class="hero-ctas">
            <a href="/work" class="btn btn-primary">
              View My Work
              <span class="btn-arrow">&rarr;</span>
            </a>
            <a href="/contact" class="btn btn-secondary">
              Get in Touch
            </a>
          </div>
        </div>

        <div class="scroll-indicator" aria-hidden="true">
          <span class="scroll-line"></span>
        </div>
      </div>
    </section>

    <!-- Brands Logo Bar -->
    <section class="logo-bar" data-reveal>
      <div class="logo-bar-inner">
        <p class="logo-bar-label">Brands I've Worked With</p>
        <div class="logo-bar-brands">
          <span class="brand-name">Razer</span>
          <span class="brand-name">KRAFTON</span>
          <span class="brand-name">ANA</span>
          <span class="brand-name">PUBG</span>
          <span class="brand-name">LG</span>
        </div>
      </div>
    </section>

    <!-- About Preview -->
    <section class="about-preview section" data-reveal>
      <div class="container">
        <div class="preview-content">
          <p class="preview-highlight">
            Most brands don't fail because they lack creativity.<br />
            They fail because, at some point, they lose clarity.
          </p>
          <p class="preview-text">
            My work sits at the intersection of brand narrative and structure. I help brands articulate who they are so that every decision that follows has a clear foundation to build on.
          </p>
          <a href="/about" class="preview-link">
            Read more about me &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- Featured Work Preview -->
    <section class="work-preview section" data-reveal>
      <div class="container">
        <span class="section-label">Selected Work</span>
        <h2 class="section-title">Case Studies</h2>
        <p class="section-subtitle">
          Case studies from gaming, tech, and lifestyle brands
        </p>
        <a href="/work" class="btn btn-secondary">
          View All Work &rarr;
        </a>
      </div>
    </section>

    <div data-reveal>
      <Subscribe />
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-bg-primary);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 44vw;
    align-items: stretch;
    gap: 0;
    max-width: 100%;
    padding-right: 0;
    text-align: left;
  }

  .hero-left {
    grid-column: 1;
    order: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    align-self: center;
    padding-right: var(--space-16);
  }

  .hero-right {
    grid-column: 2;
    order: 2;
    position: relative;
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
    height: 100vh;
    overflow: hidden;
    align-self: stretch;
  }

  .hero-photo {
    width: 100%;
    height: 100%;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: top center;
    mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.6) 10%, black 25%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.6) 10%, black 25%);
  }

  .hero-narrative {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hero-greeting {
    font-size: 1rem;
    font-weight: 300;
    color: #888;
    margin: 0;
  }

  .hero-name {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 4vw + 2rem, 6rem);
    font-weight: var(--font-bold);
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: var(--tracking-tight);
  }

  .hero-title {
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin: 0;
    margin-top: var(--space-2);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    margin: 0;
    margin-top: var(--space-6);
    line-height: var(--leading-snug);
  }

  .hero-intro {
    font-size: var(--text-lg);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    margin: 0;
    margin-top: var(--space-4);
  }

  .hero-topics {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .hero-description {
    font-size: var(--text-lg);
    color: var(--color-text-tertiary);
    font-style: italic;
    margin: 0;
  }

  .hero-role {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0;
    margin-top: var(--space-4);
  }

  .hero-ctas {
    display: flex;
    gap: var(--space-4);
  }

  .scroll-indicator {
    grid-column: 1 / -1;
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-6);
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    border-radius: var(--radius-lg);
    transition: all var(--transition-base);
    cursor: pointer;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--gradient-accent);
    color: #ffffff;
    border: none;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  .btn-arrow {
    transition: transform var(--transition-base);
  }

  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
  }

  .scroll-line {
    width: 2px;
    height: 32px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    border-radius: var(--radius-full);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% {
      opacity: 1;
      transform: scaleY(1);
    }
    50% {
      opacity: 0.5;
      transform: scaleY(0.8);
    }
  }

  /* Hero entrance animations */
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-greeting {
    animation: heroFadeUp 0.6s ease forwards;
    animation-delay: 0.1s;
    opacity: 0;
  }

  .hero-name {
    animation: heroFadeUp 0.6s ease forwards;
    animation-delay: 0.25s;
    opacity: 0;
  }

  .hero-title {
    animation: heroFadeUp 0.6s ease forwards;
    animation-delay: 0.4s;
    opacity: 0;
  }

  .hero-tagline {
    animation: heroFadeUp 0.6s ease forwards;
    animation-delay: 0.55s;
    opacity: 0;
  }

  .hero-ctas {
    animation: heroFadeUp 0.6s ease forwards;
    animation-delay: 0.7s;
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-greeting,
    .hero-name,
    .hero-title,
    .hero-tagline,
    .hero-ctas {
      animation: none;
      opacity: 1;
    }
  }

  /* Text utilities */
  .text-secondary {
    color: var(--color-text-secondary);
  }

  /* Logo Bar */
  .logo-bar {
    border-top: 1px solid #eeeeee;
    border-bottom: 1px solid #eeeeee;
    padding: var(--space-10) 0;
  }

  .logo-bar-inner {
    max-width: 900px;
    margin-inline: auto;
    padding-inline: var(--container-padding-x);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
  }

  .logo-bar-label {
    font-size: 0.75rem;
    font-weight: var(--font-medium);
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .logo-bar-brands {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-6) var(--space-10);
  }

  .brand-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: #cccccc;
    transition: color 0.2s ease;
    cursor: default;
  }

  .brand-name:hover {
    color: #1a1a1a;
  }

  /* About Preview */
  .about-preview {
    background-color: var(--color-bg-secondary);
  }

  .preview-content {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .preview-highlight {
    font-size: var(--text-xl);
    font-weight: var(--font-medium);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-6);
  }

  .preview-text {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0 0 var(--space-6);
  }

  .preview-link {
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .preview-link:hover {
    opacity: 0.8;
  }

  /* Work Preview */
  .work-preview {
    text-align: center;
  }

  .section-label {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-4);
  }

  .section-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .section-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
    }

    .hero-content {
      grid-template-columns: 1fr;
      padding-right: var(--container-padding-x);
      text-align: center;
      gap: var(--space-8);
    }

    .hero-left {
      order: 2;
      padding-right: 0;
      align-self: auto;
    }

    .hero-right {
      order: 1;
      height: auto;
      overflow: visible;
      justify-content: center;
    }

    .hero-photo {
      max-width: 240px;
      height: auto;
      margin-inline: auto;
    }

    .hero-photo img {
      height: auto;
      object-fit: cover;
      mask-image: none;
      -webkit-mask-image: none;
    }

    .hero-ctas {
      justify-content: center;
    }

    .scroll-indicator {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .hero-narrative {
      gap: var(--space-3);
    }

    .hero-title {
      font-size: var(--text-base);
    }

    .hero-tagline {
      font-size: var(--text-lg);
    }

    .hero-intro,
    .hero-topics,
    .hero-description {
      font-size: var(--text-base);
    }

    .hero-role {
      font-size: var(--text-sm);
    }

    .hero-name {
      font-size: 2.5rem;
    }

    .hero-ctas {
      flex-direction: column;
      width: 100%;
      margin-top: var(--space-6);
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 375px) {
    .logo-bar-brands {
      gap: var(--space-4) var(--space-6);
    }

    .brand-name {
      font-size: 1rem;
    }
  }
</style>
