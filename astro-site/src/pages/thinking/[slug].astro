---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import RelatedLinksSection from '../../components/seo/RelatedLinksSection.astro';
import {
  getRelatedCaseStudiesForPost,
  getRelatedExpertiseForPost,
} from '../../data/expertise';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const relatedExpertise = getRelatedExpertiseForPost(post.slug);
const relatedCaseStudies = getRelatedCaseStudiesForPost(post.slug);
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Thinking', href: '/thinking' },
  { label: post.data.title },
];
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    author: {
      '@type': 'Person',
      name: post.data.author,
    },
    url: `https://nakyumsong.com/thinking/${post.slug}/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.label,
      item: crumb.href ? `https://nakyumsong.com${crumb.href}` : undefined,
    })),
  },
];

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-SG', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={`${post.data.title} | Nakyum Song`}
  description={post.data.description}
  ogImage={post.data.ogImage}
  ogType="article"
  structuredData={structuredData}
>
  <div class="tp-page">

    <!-- Top bar -->
    <div class="tp-topbar">
      <a href="/#thinking" class="tp-back">← Back to Portfolio</a>
      <a href="/" class="tp-home-link">nakyumsong.com</a>
    </div>

    <main class="tp-main">

      <!-- Hero -->
      <div class="tp-hero">
        <Breadcrumbs items={breadcrumbItems} />
        <div class="tp-category">{post.data.category}</div>
        <h1 class="tp-title">{post.data.title}</h1>
        <div class="tp-meta">
          <span class="tp-meta-item">
            <span class="tp-meta-label">Author</span>{post.data.author}
          </span>
          <span class="tp-meta-sep">·</span>
          <span class="tp-meta-item">
            <span class="tp-meta-label">Published</span>{formattedDate}
          </span>
        </div>
        <p class="tp-description">{post.data.description}</p>
        {post.data.tags && (
          <div class="tp-tags">
            {post.data.tags.map((tag: string) => (
              <span class="tp-tag">{tag}</span>
            ))}
          </div>
        )}
      </div>

      <!-- Article body -->
      <div class="tp-body">
        <div class="tp-section-head">
          <span class="tp-sh-dash">—</span>
          <span class="tp-sh-title">Essay</span>
        </div>
        <div class="tp-section-body prose">
          <Content />
        </div>
      </div>

      <RelatedLinksSection
        eyebrow="Expertise"
        title="Related expertise"
        intro="These pages connect the essay to service and portfolio entry points without changing the editorial tone."
        items={relatedExpertise}
      />

      <RelatedLinksSection
        eyebrow="Proof"
        title="Related case studies"
        items={relatedCaseStudies}
      />

    </main>

    <!-- Footer CTA -->
    <div class="tp-footer">
      <div class="tp-footer-inner">
        <p class="tp-footer-label">005 &nbsp; Contact</p>
        <h2>Open for brand strategy, narrative consulting, and creative direction.</h2>
        <div class="tp-footer-actions">
          <a href="/#contact" class="tp-btn-accent">Get in touch →</a>
          <a href="/#thinking" class="tp-btn-outline">← Back to Portfolio</a>
        </div>
      </div>
      <div class="tp-footer-bar">
        <span>© 2026 Nakyum Song</span>
        <span>Singapore / Seoul</span>
        <a href="https://www.linkedin.com/in/nakyumsong" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .tp-page {
    background: var(--color-bg-secondary);
    min-height: 100vh;
    font-family: "Outfit", sans-serif;
  }

  /* ─── TOP BAR ─── */
  .tp-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 3.5rem;
    background: #141414;
    border-bottom: 1px solid rgba(255,79,135,0.18);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .tp-back {
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(232,228,220,0.5);
    text-decoration: none;
    transition: color 0.15s;
  }
  .tp-back:hover { color: var(--color-neon); }
  .tp-home-link {
    font-family: "Space Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    color: rgba(232,228,220,0.2);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .tp-home-link:hover { color: rgba(232,228,220,0.5); }

  /* ─── MAIN ─── */
  .tp-main {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 3.5rem 4rem;
  }

  /* ─── HERO ─── */
  .tp-hero {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }
  .tp-category {
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: 0.8rem;
  }
  .tp-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text-primary);
    margin-bottom: 1.4rem;
  }
  .tp-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.4rem;
  }
  .tp-meta-item {
    font-family: "Space Mono", monospace;
    font-size: 0.62rem;
    color: var(--color-text-secondary);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .tp-meta-label {
    font-size: 0.52rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-tertiary);
  }
  .tp-meta-sep { color: var(--color-border); }
  .tp-description {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 640px;
    margin-bottom: 1.4rem;
  }
  .tp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tp-tag {
    font-family: "Space Mono", monospace;
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--color-border);
    color: var(--color-text-tertiary);
  }

  /* ─── BODY ─── */
  .tp-body {
    background: var(--color-bg-primary);
    border-bottom: 1px solid var(--color-border);
  }
  .tp-section-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 1.4rem 1.8rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }
  .tp-sh-dash { color: var(--color-accent); font-family: "Space Mono", monospace; font-size: 0.75rem; }
  .tp-sh-title { font-family: "Space Mono", monospace; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-text-primary); font-weight: 500; }

  .tp-section-body {
    padding: 2.5rem 1.8rem 3rem;
  }

  /* ─── PROSE ─── */
  .prose {
    max-width: 640px;
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .prose :global(h2) {
    font-family: "Outfit", sans-serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.02em;
  }

  .prose :global(h3) {
    font-family: "Outfit", sans-serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text-primary);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.2rem;
    font-weight: 300;
  }

  .prose :global(strong) {
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-accent-dim);
    transition: border-color 0.15s;
  }
  .prose :global(a:hover) {
    border-bottom-color: var(--color-accent);
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 0;
    margin: 0 0 1.2rem;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .prose :global(li) {
    padding-left: 1.2rem;
    position: relative;
    font-weight: 300;
  }
  .prose :global(ul li)::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-family: "Space Mono", monospace;
    font-size: 0.7rem;
  }
  .prose :global(ol) {
    counter-reset: ol-counter;
  }
  .prose :global(ol li) {
    counter-increment: ol-counter;
  }
  .prose :global(ol li)::before {
    content: counter(ol-counter, decimal-leading-zero);
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-family: "Space Mono", monospace;
    font-size: 0.62rem;
    top: 0.15em;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 1.2rem;
    margin: 1.5rem 0;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .prose :global(code) {
    font-family: "Space Mono", monospace;
    font-size: 0.85em;
    background: var(--color-bg-tertiary);
    padding: 0.1em 0.35em;
  }

  .prose :global(pre) {
    padding: 1.4rem;
    background: #141414;
    color: #e8e4dc;
    overflow-x: auto;
    margin: 1.5rem 0;
    border: 1px solid rgba(255,255,255,0.07);
  }

  .prose :global(pre code) {
    background: transparent;
    padding: 0;
    color: inherit;
    font-size: 0.82rem;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.88rem;
  }
  .prose :global(th),
  .prose :global(td) {
    padding: 0.7rem 1rem;
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .prose :global(th) {
    background: var(--color-bg-secondary);
    font-weight: 500;
    font-family: "Space Mono", monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-primary);
  }

  /* ─── FOOTER ─── */
  .tp-footer {
    background: #141414;
    color: #e8e4dc;
    margin-top: 0;
  }
  .tp-footer-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 3.5rem 3rem;
  }
  .tp-footer-label {
    font-family: "Space Mono", monospace;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: var(--color-accent);
    margin-bottom: 1.2rem;
  }
  .tp-footer h2 {
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 2rem;
    color: #e8e4dc;
    max-width: 520px;
  }
  .tp-footer-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .tp-btn-accent {
    font-family: "Space Mono", monospace;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.8rem 1.6rem;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    transition: background 0.2s;
    display: inline-block;
  }
  .tp-btn-accent:hover { background: var(--color-accent-hover); }
  .tp-btn-outline {
    font-family: "Space Mono", monospace;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.8rem 1.6rem;
    border: 1px solid rgba(232,228,220,0.2);
    color: rgba(232,228,220,0.6);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    display: inline-block;
  }
  .tp-btn-outline:hover { border-color: rgba(232,228,220,0.5); color: #e8e4dc; }
  .tp-footer-bar {
    max-width: 860px;
    margin: 0 auto;
    padding: 1rem 3.5rem;
    display: flex;
    justify-content: space-between;
    font-family: "Space Mono", monospace;
    font-size: 0.55rem;
    color: rgba(232,228,220,0.18);
    letter-spacing: 0.08em;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .tp-footer-bar a { color: rgba(232,228,220,0.18); text-decoration: none; }
  .tp-footer-bar a:hover { color: var(--color-accent); }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    .tp-topbar, .tp-main, .tp-footer-inner, .tp-footer-bar { padding-left: 1.5rem; padding-right: 1.5rem; }
    .tp-section-body { padding-left: 1.2rem; padding-right: 1.2rem; }
  }
</style>
