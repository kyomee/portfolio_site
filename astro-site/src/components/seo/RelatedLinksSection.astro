---
import type { LinkCard } from '../../data/expertise';

interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  items: LinkCard[];
}

const { eyebrow, title, intro, items } = Astro.props;
---

{items.length > 0 && (
  <section class="related-section">
    {eyebrow && <span class="related-eyebrow">{eyebrow}</span>}
    <h2 class="related-title">{title}</h2>
    {intro && <p class="related-intro">{intro}</p>}

    <div class="related-grid">
      {items.map((item) => (
        <a href={item.href} class="related-card">
          <span class="related-card-eyebrow">{item.eyebrow}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          {item.meta && <span class="related-card-meta">{item.meta}</span>}
          <span class="related-card-arrow">→</span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .related-section {
    margin-top: var(--space-16);
  }

  .related-eyebrow {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-3);
  }

  .related-title {
    font-size: var(--text-2xl);
    margin: 0 0 var(--space-3);
  }

  .related-intro {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8);
    max-width: 760px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-6);
  }

  .related-card {
    display: block;
    padding: var(--space-6);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    transition: border-color var(--transition-fast), transform var(--transition-base), box-shadow var(--transition-base);
  }

  .related-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .related-card-eyebrow {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-3);
  }

  .related-card h3 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
    color: var(--color-text-primary);
  }

  .related-card p {
    margin: 0 0 var(--space-4);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .related-card-meta {
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
  }

  .related-card-arrow {
    display: block;
    margin-top: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .related-card:hover .related-card-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
