---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import RelatedLinksSection from '../components/seo/RelatedLinksSection.astro';
import {
  getRelatedExpertiseForCaseStudy,
  getRelatedPostsForCaseStudy,
} from '../data/expertise';

interface Props {
  slug: string;
  title: string;
  company: string;
  role: string;
  period: string;
  description: string;
  heroImage?: string | ImageMetadata;
  results: string[];
  objective: string;
  strategy: {
    title: string;
    points: string[];
  };
  execution: string[];
  videoUrl?: string;
}

const {
  slug,
  title,
  company,
  role,
  period,
  description,
  heroImage,
  results,
  objective,
  strategy,
  execution,
  videoUrl
} = Astro.props;

const pageTitle = `${title} | Nakyum Song`;
const relatedExpertise = getRelatedExpertiseForCaseStudy(slug);
const relatedPosts = getRelatedPostsForCaseStudy(slug);
const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Work', href: '/work' },
  { label: title },
];
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'CreativeWork',
    name: title,
    description,
    author: {
      '@type': 'Person',
      name: 'Nakyum Song',
    },
    about: company,
    url: `https://nakyumsong.com/projects/${slug}/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.label,
      item: crumb.href ? `https://nakyumsong.com${crumb.href}` : undefined,
    })),
  },
];
---

<BaseLayout title={pageTitle} description={description} structuredData={structuredData}>
  <div class="cs-page">

    <!-- Top bar -->
    <div class="cs-topbar">
      <a href="/#work" class="cs-back">← Back to Portfolio</a>
      <a href="/" class="cs-home-link">nakyumsong.com</a>
    </div>

    <main class="cs-main">

      <!-- Hero -->
      <div class="cs-hero">
        <Breadcrumbs items={breadcrumbItems} />
        <div class="cs-client">{company}</div>
        <h1 class="cs-title">{title}</h1>
        <div class="cs-meta">
          <span class="cs-meta-item"><span class="cs-meta-label">Role</span>{role}</span>
          <span class="cs-meta-sep">·</span>
          <span class="cs-meta-item"><span class="cs-meta-label">Period</span>{period}</span>
        </div>
        <p class="cs-description">{description}</p>
      </div>

      {heroImage && (
        <div class="cs-image-wrap">
          {typeof heroImage === 'string' ? (
            <img src={heroImage} alt={title} loading="lazy" decoding="async" class="cs-image" />
          ) : (
            <Image
              src={heroImage}
              alt={title}
              widths={[960, 1440]}
              sizes="(max-width: 900px) 100vw, 900px"
              format="webp"
              quality={82}
              loading="lazy"
              class="cs-image"
            />
          )}
        </div>
      )}

      <!-- Results bar -->
      <div class="cs-results-bar">
        {results.map((r) => (
          <div class="cs-result-item">{r}</div>
        ))}
      </div>

      <!-- Objective -->
      <div class="cs-section">
        <div class="cs-section-head">
          <span class="cs-sh-dash">—</span>
          <span class="cs-sh-num">01</span>
          <span class="cs-sh-title">Objective</span>
        </div>
        <div class="cs-section-body">
          <p class="cs-objective">{objective}</p>
        </div>
      </div>

      <!-- Strategy -->
      <div class="cs-section">
        <div class="cs-section-head">
          <span class="cs-sh-dash">—</span>
          <span class="cs-sh-num">02</span>
          <span class="cs-sh-title">Strategy</span>
          <span class="cs-sh-sub">{strategy.title}</span>
        </div>
        <div class="cs-section-body">
          <ul class="cs-list">
            {strategy.points.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      </div>

      <!-- Execution -->
      <div class="cs-section">
        <div class="cs-section-head">
          <span class="cs-sh-dash">—</span>
          <span class="cs-sh-num">03</span>
          <span class="cs-sh-title">Execution</span>
        </div>
        <div class="cs-section-body">
          <ul class="cs-list">
            {execution.map((e) => <li>{e}</li>)}
          </ul>
        </div>
      </div>

      <!-- Results detail -->
      <div class="cs-section">
        <div class="cs-section-head">
          <span class="cs-sh-dash">—</span>
          <span class="cs-sh-num">04</span>
          <span class="cs-sh-title">Results</span>
        </div>
        <div class="cs-section-body">
          <ul class="cs-list">
            {results.map((r) => <li>{r}</li>)}
          </ul>
          {videoUrl && (
            <a href={videoUrl} target="_blank" rel="noopener noreferrer" class="cs-video-link">
              Watch Campaign Video ↗
            </a>
          )}
        </div>
      </div>

      <RelatedLinksSection
        eyebrow="Expertise"
        title="Related expertise"
        intro="These entry points connect the case study back to audience and service intent without changing the editorial presentation."
        items={relatedExpertise}
      />

      <RelatedLinksSection
        eyebrow="Reading"
        title="Related essays"
        items={relatedPosts}
      />

    </main>

    <!-- Footer CTA -->
    <div class="cs-footer">
      <div class="cs-footer-inner">
        <p class="cs-footer-label">005 &nbsp; Contact</p>
        <h2>Open for brand strategy, narrative consulting, and creative direction.</h2>
        <div class="cs-footer-actions">
          <a href="/#contact" class="cs-btn-accent">Get in touch →</a>
          <a href="/#work" class="cs-btn-outline">← Back to Portfolio</a>
        </div>
      </div>
      <div class="cs-footer-bar">
        <span>© 2026 Nakyum Song</span>
        <span>Singapore / Seoul</span>
        <a href="https://www.linkedin.com/in/nakyumsong" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  .cs-page {
    background: var(--color-bg-secondary);
    min-height: 100vh;
    font-family: "Outfit", sans-serif;
  }

  /* ─── TOP BAR ─── */
  .cs-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 3.5rem;
    background: #141414;
    border-bottom: 1px solid rgba(255,79,135,0.18);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .cs-back {
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(232,228,220,0.5);
    text-decoration: none;
    transition: color 0.15s;
  }
  .cs-back:hover { color: var(--color-neon); }
  .cs-home-link {
    font-family: "Space Mono", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    color: rgba(232,228,220,0.2);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 0.15s;
  }
  .cs-home-link:hover { color: rgba(232,228,220,0.5); }

  /* ─── MAIN ─── */
  .cs-main {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 3.5rem 4rem;
  }

  /* ─── HERO ─── */
  .cs-hero {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }
  .cs-client {
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
    margin-bottom: 0.8rem;
  }
  .cs-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text-primary);
    margin-bottom: 1.4rem;
  }
  .cs-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.4rem;
  }
  .cs-meta-item {
    font-family: "Space Mono", monospace;
    font-size: 0.62rem;
    color: var(--color-text-secondary);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .cs-meta-label {
    font-size: 0.52rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-tertiary);
  }
  .cs-meta-sep { color: var(--color-border); }
  .cs-description {
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 640px;
  }

  /* ─── HERO IMAGE ─── */
  .cs-image-wrap {
    margin-bottom: 2.5rem;
    border: 1px solid var(--color-border);
  }
  .cs-image {
    width: 100%;
    aspect-ratio: 16 / 7;
    object-fit: cover;
    display: block;
  }

  /* ─── RESULTS BAR ─── */
  .cs-results-bar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-primary);
    margin-bottom: 3rem;
  }
  .cs-result-item {
    padding: 1.2rem 1.6rem;
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--color-text-secondary);
    line-height: 1.6;
    border-right: 1px solid var(--color-border);
  }
  .cs-result-item:last-child { border-right: none; }

  /* ─── SECTIONS ─── */
  .cs-section {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-primary);
    margin-bottom: 0;
  }
  .cs-section-head {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 1.4rem 1.8rem;
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }
  .cs-sh-dash { color: var(--color-accent); font-family: "Space Mono", monospace; font-size: 0.75rem; }
  .cs-sh-num  { font-family: "Space Mono", monospace; font-size: 0.65rem; color: var(--color-text-secondary); letter-spacing: 0.1em; }
  .cs-sh-title{ font-family: "Space Mono", monospace; font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-text-primary); font-weight: 500; }
  .cs-sh-sub  { font-family: "Space Mono", monospace; font-size: 0.6rem; color: var(--color-text-secondary); letter-spacing: 0.05em; margin-left: auto; }

  .cs-section-body {
    padding: 2rem 1.8rem;
  }

  .cs-objective {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-primary);
    line-height: 1.8;
    max-width: 640px;
  }

  .cs-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    max-width: 640px;
  }
  .cs-list li {
    font-size: 0.92rem;
    font-weight: 300;
    color: var(--color-text-secondary);
    line-height: 1.75;
    padding-left: 1.2rem;
    position: relative;
  }
  .cs-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-family: "Space Mono", monospace;
    font-size: 0.7rem;
  }

  .cs-video-link {
    display: inline-block;
    margin-top: 1.4rem;
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-accent-dim);
    padding-bottom: 1px;
    text-decoration: none;
    transition: color 0.15s;
  }
  .cs-video-link:hover { color: var(--color-accent-hover); }

  /* ─── FOOTER ─── */
  .cs-footer {
    background: #141414;
    color: #e8e4dc;
    margin-top: 0;
  }
  .cs-footer-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 3.5rem 3rem;
  }
  .cs-footer-label {
    font-family: "Space Mono", monospace;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: var(--color-accent);
    margin-bottom: 1.2rem;
  }
  .cs-footer h2 {
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 400;
    letter-spacing: -0.02em;
    line-height: 1.25;
    margin-bottom: 2rem;
    color: #e8e4dc;
    max-width: 520px;
  }
  .cs-footer-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .cs-btn-accent {
    font-family: "Space Mono", monospace;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.8rem 1.6rem;
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
    transition: background 0.2s;
    display: inline-block;
  }
  .cs-btn-accent:hover { background: var(--color-accent-hover); }
  .cs-btn-outline {
    font-family: "Space Mono", monospace;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.8rem 1.6rem;
    border: 1px solid rgba(232,228,220,0.2);
    color: rgba(232,228,220,0.6);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    display: inline-block;
  }
  .cs-btn-outline:hover { border-color: rgba(232,228,220,0.5); color: #e8e4dc; }
  .cs-footer-bar {
    max-width: 860px;
    margin: 0 auto;
    padding: 1rem 3.5rem;
    display: flex;
    justify-content: space-between;
    font-family: "Space Mono", monospace;
    font-size: 0.55rem;
    color: rgba(232,228,220,0.18);
    letter-spacing: 0.08em;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .cs-footer-bar a { color: rgba(232,228,220,0.18); text-decoration: none; }
  .cs-footer-bar a:hover { color: var(--color-accent); }

  /* ─── MOBILE ─── */
  @media (max-width: 768px) {
    .cs-topbar, .cs-main, .cs-footer-inner, .cs-footer-bar { padding-left: 1.5rem; padding-right: 1.5rem; }
    .cs-results-bar { grid-template-columns: 1fr; }
    .cs-result-item { border-right: none; border-bottom: 1px solid var(--color-border); }
    .cs-result-item:last-child { border-bottom: none; }
    .cs-sh-sub { margin-left: 0; width: 100%; }
  }
</style>
